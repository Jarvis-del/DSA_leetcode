//------------------------------------------------------------Approch---------------------------------------------------------------------//

Time Complexity: O(n)
Space Complexity: O(n)

//--------------------------------------------------------------Code-----------------------------------------------------------------------//
class Solution {
    public int[] getConcatenation(int[] nums) {
        int n = nums.length;

        int result[] = new int[2*n];
        
        for(int i=0; i<n; i++){
            result[i] = nums[i];
        }
        int j = n;
        for(int i=0; i<n; i++){
            result[j++] = nums[i];
        }
        return result;
    }
}
